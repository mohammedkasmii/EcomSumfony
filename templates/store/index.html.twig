{% extends 'base.html.twig' %}

{% block title %}Products - Our Store{% endblock %}

{% block nav_home %}active{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-4">Our Products</h1>
    <div class="row row-cols-1 row-cols-md-3 g-4">

        {% for product in products %}
        <div class="col">
            <div class="card h-100">
                <img src="{{ asset('images/item.png') }}" class="card-img-top" alt="{{ product.name }}">
                <div class="card-body">
                    <span class="badge bg-primary mb-2">{{ product.category.name }}</span>
                    <h5 class="card-title">{{ product.name }}</h5>
                    <p class="card-text fw-bold text-success">${{ product.price }}</p>
                    <a href="{{ path('app_product_details', {id: product.id}) }}" class="btn btn-outline-primary">View Details</a>
                </div>
            </div>
        </div>
        {% endfor %}

    </div>

    <nav aria-label="Product pagination" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item {% if page <= 1 %}disabled{% endif %}">
                <a class="page-link" href="{{ path('app_home', {'page': page - 1}) }}">Previous</a>
            </li>
            <li class="page-item">
                <a class="page-link" href="{{ path('app_home', {'page': page + 1}) }}">Next</a>
            </li>
        </ul>
    </nav>
</div>
{% endblock %}

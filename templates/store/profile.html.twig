{% extends 'base.html.twig' %}

{% block title %}My Profile - Our Store{% endblock %}

{% block nav_profile %}active{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">

        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center">
                    <img src="{{ asset('images/profile.png') }}" class="rounded-circle mb-3" alt="User Avatar" width="150" height="150">
                    <h5 class="card-title">{{ app.user.name }}</h5>
                    <p class="text-muted">{{ app.user.email }}</p>
                    <hr>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#profile" class="text-decoration-none">Profile Information</a></li>
                        <li class="mb-2"><a href="#orders" class="text-decoration-none">My Orders</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none">Settings</a></li>
                        <li class="mb-2"><a href="{{ path('app_login') }}" class="text-decoration-none text-danger">Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card mb-4" id="profile">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Profile Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold">Full Name:</label>
                            <p>{{ app.user.name }}</p>
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">Email:</label>
                            <p>{{ app.user.email }}</p>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold">Phone:</label>
                            <p>+1 (555) 123-4567</p>
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">Member Since:</label>
                            <p>January 15, 2024</p>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <label class="fw-bold">Shipping Address:</label>
                            <p>123 Main Street, Apt 4B<br>New York, NY 10001<br>United States</p>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary">Edit Profile</button>
                </div>
            </div>

            <div class="card" id="orders">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Order History</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted text-center py-4">You haven't placed any orders yet.</p>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
